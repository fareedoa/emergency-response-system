# ── SwiftAid Frontend Configuration ──────────────────────
# Copy this file to .env and fill in your values

# Backend Service URLs (must match application.yaml ports)
VITE_AUTH_URL=http://localhost:8081
VITE_INCIDENT_URL=http://localhost:8082
VITE_TRACKING_URL=http://localhost:8083
VITE_ANALYTICS_URL=http://localhost:8084
VITE_WS_URL=http://localhost:8083

# Google Maps API Key (required for incident location picker)
# Get one at: https://console.cloud.google.com/google/maps-apis
VITE_GOOGLE_MAPS_KEY=your_google_maps_api_key_here
